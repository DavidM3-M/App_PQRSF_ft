# ─────────────────────────────────────────────────────────────────────────────
#  Plantilla de variables de entorno
#  Copiar como .env.local para entorno de desarrollo, o .env para producción
# ─────────────────────────────────────────────────────────────────────────────

# URL base del backend Django REST
VITE_API_URL=http://localhost:8000

# Deshabilitar reCAPTCHA:
#   true  → bypassea la verificación (útil en desarrollo local)
#   false → activa el widget reCAPTCHA (requerido en producción)
VITE_DISABLE_CAPTCHA=false

# Site key pública de Google reCAPTCHA v2 (obtener en https://www.google.com/recaptcha/admin)
VITE_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY
