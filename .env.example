# ─────────────────────────────────────────────
#  Variables de entorno para el frontend PQRSF
#  Copia este archivo a .env.local y rellena los valores
# ─────────────────────────────────────────────

# URL base del backend Django
VITE_API_URL=http://localhost:8000

# Deshabilitar reCAPTCHA en desarrollo local (true | false)
# IMPORTANTE: mantener en false en producción.
VITE_DISABLE_CAPTCHA=false

# Client ID de Google OAuth 2.0
# Obtenlo en: https://console.cloud.google.com/ → APIs & Services → Credentials
# Crea un OAuth 2.0 Client ID de tipo "Web application"
# Agrega en "Authorized JavaScript origins": http://localhost:5173
# Agrega en "Authorized redirect URIs": http://localhost:5173
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
